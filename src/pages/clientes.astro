---
import Breadcrumb from '@/components/Breadcrumb.astro';
import PageHeader from '@/components/PageHeader.astro';
import SeoHead from '@/components/SeoHead.astro';
import { clientsMock } from '@/content/clientsMock';
import Layout from '@/layouts/Layout.astro';
import ClientsCards from '@/sections/home/components/ClientsCards.astro';
const SeoContent = {
  title: 'Clientes que confían en nosotros | Lagunas Claras',
  description:
    'Empresas, municipios e instituciones de todo el país que confían en nuestros servicios de mantenimiento de lagos y espejos de agua.',
};
const content = {
  title: 'Clientes',
  subtitle: 'Instituciones que confían en nuestros servicios',
};
---

<Layout>
  <SeoHead title={SeoContent.title} description={SeoContent.description} />
  <Fragment slot="main">
    <main class="bg-background mx-auto mt-24 min-h-screen w-[80%] pb-20">
      <Breadcrumb items={[{ label: 'Clientes' }]} />
      <PageHeader title={content.title} subtitle={content.subtitle} />

      <ClientsCards services={clientsMock} />
    </main>
  </Fragment>
</Layout>
