---
import Breadcrumb from '@/components/Breadcrumb.astro';
import ContactCardsList from '@/components/ContactCardsList.astro';
import MapIframe from '@/components/MapIframe.astro';
import PageHeader from '@/components/PageHeader.astro';
import SeoHead from '@/components/SeoHead.astro';
import Layout from '@/layouts/Layout.astro';
import ContactForm from '@/sections/contactUs/components/ContactForm.astro';

const SeoContent = {
  title: 'Contacto | Lagunas Claras',
  description:
    'Contactanos para recibir asesoramiento y presupuestos sin cargo sobre mantenimiento y recuperación de lagos y espejos de agua.',
};
const PageContent = {
  title: 'Contactanos',
  description:
    'Completá el formulario y nos pondremos en contacto a la brevedad para atender tu consulta',
};
const pathName = Astro.url.pathname;
---

<Layout>
  <SeoHead title={SeoContent.title} description={SeoContent.description} />
  <Fragment slot="main">
    <Breadcrumb items={[{ label: 'Contacto', href: pathName }]} className={'mt-24 ml-[10%]'} />
    <PageHeader title={PageContent.title} subtitle={PageContent.description} />
    <div
      class="from-primary/10 mx-auto mb-16 max-w-7xl rounded-2xl border border-slate-200 bg-linear-to-br to-green-500/10 px-4 py-8 shadow-xl sm:px-6 lg:px-8"
    >
      <!-- Main Content: Form + Contact Info -->
      <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:gap-6">
        <!-- Form Section (larger on desktop) -->
        <div class="w-full lg:w-[65%]">
          <ContactForm {...PageContent} />
        </div>

        <!-- Contact Info Section (smaller on desktop, full width on mobile/tablet) -->
        <div class="flex w-full flex-col gap-6 lg:w-[35%]">
          <ContactCardsList />
          <MapIframe className="h-60 w-full overflow-hidden rounded-2xl" />
        </div>
      </div>
    </div>
  </Fragment>
</Layout>
