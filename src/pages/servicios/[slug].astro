---
import SeoHead from '@/components/SeoHead.astro';
import Layout from '@/layouts/Layout.astro';
import ServiceCTA from '@/sections/services/ServiceCTA.astro';
import ServiceExplanation from '@/sections/services/ServiceExplanation.astro';
import ServiceGallery from '@/sections/services/ServiceGallery.astro';
import ServiceHero from '@/sections/services/ServiceHero.astro';
import ServiceHowWeDoIt from '@/sections/services/ServiceHowWeDoIt.astro';
import ServiceProblem from '@/sections/services/ServiceProblem.astro';
import ServiceProcess from '@/sections/services/ServiceProcess.astro';
import { getCollection } from 'astro:content';

import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.data.slug || service.id.replace(/\.mdx?$/, '') },
    props: { service },
  }));
}

interface Props {
  service: CollectionEntry<'services'>;
}

const { service } = Astro.props;
const { data } = service;
const { Content } = await service.render();
---

<Layout title={`${data.title} | Lagunas Claras`} description={data.shortDescription}>
  <SeoHead
    title={`${data.title} | Lagunas Claras`}
    description={data.shortDescription}
    ogImage={data.hero.image.src}
  />
  <ServiceHero
    title={data.title}
    subtitle={data.subtitle || data.shortDescription}
    badge={data.badge || 'Servicio'}
    heroImage={data.hero.image}
    heroAlt={data.hero.alt}
    ctaHref="/contacto"
  />

  <div class="from-background via-primary-soft/10 to-primary-light/10 bg-linear-to-b">
    {
      data.problem && (
        <ServiceProblem
          title={data.problem.title}
          description={data.problem.description}
          bullets={data.problem.bullets}
        />
      )
    }

    <ServiceExplanation>
      <Content />
    </ServiceExplanation>

    {data.process && <ServiceProcess steps={data.process} />}

    {
      data.howWeDoIt && (
        <ServiceHowWeDoIt
          title={data.howWeDoIt.title}
          steps={data.howWeDoIt.steps}
          image={data.howWeDoIt.image}
          video={data.howWeDoIt.video}
        />
      )
    }

    {
      data.machinery && (
        <ServiceGallery
          title={data.machinery.title}
          subtitle={data.machinery.subtitle || ''}
          gallery={data.machinery.gallery}
        />
      )
    }

    {/* Gallery */}
    <ServiceGallery gallery={data.gallery} beforeAfter={data.beforeAfter} />

    <ServiceCTA
      title={data.cta ? data.cta.title : 'Solicitá tu cotización hoy mismo'}
      buttonText={data.cta ? data.cta.buttonText : 'Contactar'}
    />
  </div>
</Layout>
