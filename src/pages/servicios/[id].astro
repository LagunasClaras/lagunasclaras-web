---
import Breadcrumb from '@/components/Breadcrumb.astro';
import Button from '@/components/Button.astro';
import PageHeader from '@/components/PageHeader.astro';
import SeoHead from '@/components/SeoHead.astro';
import VideoModal from '@/components/VideoModal.astro';
import { SERVICE_PAGE_TEXTS } from '@/constants/servicePage';
import Layout from '@/layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'services'>;
}

const { entry } = Astro.props;
const { title, description, image: rawImage, features, video, resumeVideo, specialty } = entry.data;

const image = rawImage && rawImage.startsWith('src/') ? `/${rawImage}` : rawImage;

const seoTitle = `${title} | Lagunas Claras`;
---

<Layout>
  <SeoHead title={seoTitle} description={description} />
  <Fragment slot="main">
    <main class="bg-background mx-auto mt-24 min-h-screen w-[80vw] pb-20">
      <Breadcrumb
        items={[
          { label: 'Servicios', href: '/servicios' },
          { label: title, href: '' },
        ]}
      />
      <!-- Header -->
      <section class="mx-auto mb-12 text-start">
        {
          specialty && (
            <span class="text-primary/80 mb-2 block text-sm font-semibold tracking-wider uppercase">
              {SERVICE_PAGE_TEXTS.specialtyLabel(specialty)}
            </span>
          )
        }
        <PageHeader title={title} subtitle={description} />
      </section>

      <!-- Main Content -->
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid gap-12 lg:grid-cols-2">
          <!-- Left Column: Image/Video -->
          <div class="flex flex-col gap-6">
            {
              image && (
                <div class="aspect-video w-full overflow-hidden rounded-2xl shadow-lg">
                  <img src={image} alt={title} class="h-full w-full object-cover" />
                </div>
              )
            }

            {
              (video || resumeVideo) && (
                <div class="bg-muted/30 rounded-2xl p-6">
                  <h3 class="mb-4 text-xl font-semibold">{SERVICE_PAGE_TEXTS.videoTitle}</h3>
                  {/* Placeholder for video player or link - using resumeVideo if available as preview or video as full */}
                  <div class="flex aspect-video w-full items-center justify-center overflow-hidden rounded-xl bg-black/10">
                    <span class="text-muted-foreground">{SERVICE_PAGE_TEXTS.videoPlaceholder}</span>
                  </div>
                  <div class="mt-4 flex gap-2">
                    {video && (
                      <Button
                        variant="underline"
                        class="w-full text-lg"
                        data-video-trigger
                        data-video-src={video}
                      >
                        {SERVICE_PAGE_TEXTS.viewFullVideo}
                      </Button>
                    )}
                  </div>
                </div>
              )
            }
          </div>

          <!-- Right Column: Features & Details -->
          <div class="flex flex-col gap-8">
            <div class="border-primary/10 bg-primary/5 rounded-3xl border p-8">
              <h2 class="text-primary mb-6 text-2xl font-bold">
                {SERVICE_PAGE_TEXTS.featuresTitle}
              </h2>

              {
                features && features.length > 0 ? (
                  <ul class="flex flex-col gap-4">
                    {features.map((feature) => (
                      <li class="flex items-start gap-3">
                        <div class="bg-primary/10 text-primary mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full">
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="3"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="lucide lucide-check"
                          >
                            <path d="M20 6 9 17l-5-5" />
                          </svg>
                        </div>
                        <span class="text-foreground/80">{feature}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class="text-muted-foreground">{SERVICE_PAGE_TEXTS.contactFallback}</p>
                )
              }

              <div class="border-primary/10 mt-8 border-t pt-8">
                <h3 class="mb-4 text-lg font-semibold">{SERVICE_PAGE_TEXTS.contactPrompt}</h3>
                <Button href="/contacto" variant="primary" class="w-full text-lg">
                  {SERVICE_PAGE_TEXTS.contactButton}
                </Button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
    <VideoModal />
  </Fragment>
</Layout>
