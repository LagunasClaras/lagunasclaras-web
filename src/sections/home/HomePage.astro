---
import { clientsContent } from '@/content/clients';
import { DropMagnifying, ShieldEngine, WaterReclying } from '@icons';
import AboutUsSection from './components/AboutUsSection.astro';
import ClientsSection from './components/ClientsSection.astro';
import HeroSection from './components/HeroSection.astro';
import type { AboutUsProps } from './types/AboutUs.types';
import type { ContactSectionProps } from './types/Contact.types';
import type { HeroProps } from './types/Hero.types';
import type { ServiceCardBase } from './types/ServiceCard.types';
// Import client logos
import ScrollIndicator from '@/components/ScrollIndicator.astro';
import ContactSection from './components/ContactSection.astro';

// Hero Content
const heroContent: HeroProps = {
  HeroTitle: 'Mantenimiento y recuperación de lagos y ecosistemas acuáticos',
  HeroSubtitle:
    'Tecnología sustentable y enfoque biológico integral para preservar la belleza natural de sus espejos de agua',
  CTA: [
    { text: 'Contactanos', href: '/contacto', style: 'primary' },
    { text: 'Ver servicios', href: '/servicios', style: 'underline' },
  ],
  Discover: { text: 'Descubre más', href: '#about-us' },
};

// About Us Content
const aboutUsContent: Omit<AboutUsProps, 'serviceCards'> = {
  sectionHeader: 'Quienes Somos?',
  title: 'Especialistas en el cuidado de ecosistemas acuáticos',
  body: 'Hace más de una década trabajamos en la limpieza y recuperación de lagos y espejos de agua en todo el país. Diseñamos y operamos maquinaria especializada que permite eliminar vegetación acuática y residuos flotantes de forma eficiente, sustentable y sin químicos, cuidando la salud del ecosistema en cada intervención.',
  viewMore: 'Ver más',
  viewMoreText: 'Ver detalle',
};

// Service Cards Data
const serviceCards: ServiceCardBase[] = [
  {
    title: 'Diagnóstico y Evaluación',
    shortDescription: 'dolor sit amet consectetur',
    Icon: DropMagnifying,
  },
  {
    title: 'Limpieza y Recuperación',
    shortDescription: 'Lorem ipsum dolor sit amet consectetur',
    Icon: WaterReclying,
  },
  {
    title: 'Mantenimiento Integral',
    shortDescription: 'dolor sit amet consectetur',
    Icon: ShieldEngine,
  },
];

// Contact Section Props

const contactSectionContent: ContactSectionProps = {
  title: '¿Querés recuperar la claridad de tu espejo de agua?',
  description:
    'Contanos tu necesidad y nuestro equipo te asesora sin cargo con una solución adaptada a tu entorno.',
  cta: 'Contactanos',
};
---

<HeroSection {...heroContent} />
<div class="flex min-h-[calc(100vh-80px)] flex-col items-center justify-center gap-2 pt-16">
  <AboutUsSection {...aboutUsContent} serviceCards={serviceCards} />
  <ClientsSection {...clientsContent} />
  <ScrollIndicator
    href="#contact-us-section"
    text="Descubre más"
    id="scroll-to-contact"
    linkClass="text-slate-600 hover:text-slate-900"
  />
</div>
<div class="w-full pt-20">
  <ContactSection {...contactSectionContent} />
</div>
