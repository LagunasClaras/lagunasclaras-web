---
import ClientCard from '@/components/ClientCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  clients: CollectionEntry<'clientes'>[];
}

const { clients } = Astro.props;
---

<section class="bg-background py-12">
  <div class="mx-auto max-w-7xl px-4 md:px-6">
    <!-- Clients Grid Container -->
    <div class="grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-6 lg:grid-cols-4 lg:gap-8" role="list">
      {
        clients.map((client) => (
          <div class="w-full">
            <ClientCard client={client} />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Ensure the grid feels balanced */
  .grid {
    grid-auto-rows: min-content;
  }
</style>
