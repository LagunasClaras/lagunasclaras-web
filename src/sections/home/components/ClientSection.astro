---
import type { ClientsProps } from '../types/Clients.types';

const { sectionTitle, sectionDescription, clients } = Astro.props as ClientsProps;
---

<section class="mx-auto w-[80vw] py-16">
  {
    sectionTitle && (
      <h2 class="mb-4 text-center text-3xl font-bold text-slate-900">{sectionTitle}</h2>
    )
  }
  {
    sectionDescription && (
      <p class="mx-auto mb-12 max-w-2xl text-center text-slate-700">{sectionDescription}</p>
    )
  }

  <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-10 md:gap-x-20 md:gap-y-16">
    {
      clients.map((client) => (
        <div class="flex items-center justify-center opacity-70 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0">
          <img
            src={client.imageUrl}
            alt={client.alt}
            loading="lazy"
            title={client.name}
            class="h-10 w-auto object-contain md:h-14 lg:h-16"
          />
        </div>
      ))
    }
  </div>
</section>
