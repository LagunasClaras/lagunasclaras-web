---
import { Image } from 'astro:assets';
import type { ClientsProps } from '../types/Clients.types';
import './ClientsSection.styles.css';
const { clients, sectionDescription } = Astro.props as ClientsProps;
---

<section class="relative mx-auto w-[80%] overflow-hidden py-12">
  <div class="mx-auto max-w-6xl px-4">
    <h3 class="text-muted-foreground mb-8 text-center text-lg font-semibold">
      {sectionDescription}
    </h3>
  </div>

  <div class="carousel-container">
    <div class="carousel-track">
      {/* First set of clients */}
      <div class="carousel-slide">
        {
          clients.map((client) => (
            <div class="client-card">
              <Image src={client.image} alt={client.alt} height={80} class="client-img" />
            </div>
          ))
        }
      </div>
      {/* Duplicate set for infinite loop */}
      <div class="carousel-slide" aria-hidden="true">
        {
          clients.map((client) => (
            <div class="client-card">
              <Image src={client.image} alt={client.alt} height={80} class="client-img" />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
