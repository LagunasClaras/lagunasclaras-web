---
import Hero from '@/components/Hero.astro';
import fondoHero from '@assets/fondo4-D.webp';
import fondoHeroMobile from '@assets/fondo4-M.webp';
import type { HeroProps } from '../types/Hero.types';

const { HeroTitle, HeroSubtitle, CTA, Discover } = Astro.props as HeroProps;
---

<Hero
  variant="home"
  title={HeroTitle}
  subtitle={HeroSubtitle}
  image={fondoHero}
  imageMobile={fondoHeroMobile}
  cta={CTA.map((c: any) => ({
    text: c.text,
    href: c.href,
    variant: c.style,
    icon: true,
  }))}
  showScrollIndicator={true}
  scrollIndicatorHref={Discover.href}
  scrollIndicatorText={Discover.text}
/>
