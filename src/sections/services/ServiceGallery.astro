---
import GalleryModal from '@/components/GalleryModal.astro';
import { ArrowLeftRight, Play, Image as ImageIcon } from '@lucide/astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { BeforeAfter } from './ServiceBeforeAfter.astro';
import ServiceBeforeAfter from './ServiceBeforeAfter.astro';

type GalleryItem =
  | { type: 'image'; src: ImageMetadata; poster?: never }
  | { type: 'video'; src: string; poster?: ImageMetadata };

interface Props {
  title?: string;
  subtitle?: string;
  gallery?: GalleryItem[];
  beforeAfter?: BeforeAfter;
}

const {
  title = 'Resultados Visibles',
  subtitle = 'Transformamos espejos de agua deteriorados en ecosistemas saludables y estéticamente agradables.',
  gallery = [],
  beforeAfter,
} = Astro.props;

function getYouTubeId(url: string) {
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|shorts\/|watch\?v=|&v=)([^#&?]*).*/;
  const match = url.match(regExp);
  return match && match[2].length === 11 ? match[2] : null;
}
---

<section class="w-full py-12 md:py-16">
  <div class="container mx-auto px-6 md:px-12">
    {
      (title || subtitle) && (
        <div class="mb-12 text-center">
          {title && <h2 class="text-primary mb-4 text-3xl font-bold md:text-4xl">{title}</h2>}
          {subtitle && <p class="mx-auto max-w-2xl text-gray-600">{subtitle}</p>}
        </div>
      )
    }

    {/* Before & After Results */}
    {beforeAfter && <ServiceBeforeAfter beforeAfter={beforeAfter} />}
    {/* Gallery Grid */}
    {
      gallery.length > 0 && (
        <div
          class={
            gallery.length === 1
              ? 'mx-auto w-full max-w-5xl'
              : 'grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3'
          }
          data-gallery-group
        >
          {gallery.map((item, index) => {
            const serializedItem = JSON.stringify({
              type: item.type,
              src: item.type === 'image' ? item.src.src : item.src,
              poster: item.poster?.src,
            });

            return (
              <div
                class="group reveal-gallery-item relative aspect-video translate-y-4 cursor-pointer overflow-hidden rounded-xl bg-gray-200 opacity-0 shadow-md transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
                style={`transition-delay: ${index * 100}ms`}
                data-gallery-trigger
                data-gallery-item={serializedItem}
              >
                {/* Image/Video Thumbnail */}
                {item.type === 'video' ? (
                  item.poster ? (
                    <Image
                      src={item.poster}
                      alt={`Galería ${index + 1}`}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                  ) : getYouTubeId(item.src) ? (
                    <img
                      src={`https://i.ytimg.com/vi/${getYouTubeId(item.src)}/hqdefault.jpg`}
                      alt={`Galería ${index + 1}`}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  ) : (
                    <div class="flex h-full w-full items-center justify-center bg-gray-200">
                      <Play class="h-12 w-12 text-gray-400" />
                    </div>
                  )
                ) : item.type === 'image' ? (
                  <Image
                    src={item.src}
                    alt={`Galería ${index + 1}`}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                ) : null}

                <div class="from-navy-900/40 absolute inset-0 bg-linear-to-br to-transparent opacity-0 transition-opacity group-hover:opacity-100" />

                <div class="absolute inset-0 flex items-center justify-center">
                  {item.type === 'video' ? (
                    <div class="flex h-16 w-16 items-center justify-center rounded-full bg-white/20 backdrop-blur-sm transition-transform group-hover:scale-110">
                      <Play class="ml-1 h-8 w-8 fill-current text-white" />
                    </div>
                  ) : (
                    <ImageIcon class="h-10 w-10 scale-50 transform text-white/0 transition-all duration-300 group-hover:scale-100 group-hover:text-white" />
                  )}
                </div>
              </div>
            );
          })}
        </div>
      )
    }

    <GalleryModal />
  </div>
  <script>
    function setupGallery() {
      // Gallery Reveal Animation
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.remove('opacity-0', 'translate-y-4');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );

      document.querySelectorAll('.reveal-gallery-item').forEach((el) => observer.observe(el));
    }

    document.addEventListener('astro:page-load', setupGallery);
  </script>
</section>
