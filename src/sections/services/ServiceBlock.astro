---
import Button from '@/components/Button.astro';
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import clsx from 'clsx';

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  buttonRoute: string;
  reverse?: boolean;
}

const { title, description, image, reverse = false, buttonRoute } = Astro.props;
const gradientClass = reverse
  ? 'md:bg-linear-to-l md:rounded-r-full md:rounded-tl-none'
  : 'md:bg-linear-to-r md:rounded-l-full md:rounded-tr-none';
---

<section
  class={clsx(
    'bg-linear-to-b rounded-tr-4xl rounded-tl-4xl rounded-r-none rounded-l-none from-primary-light/20 to-background px-8 py-8 ',
    gradientClass
  )}
>
  <div class={clsx('mx-auto max-w-6xl', 'grid items-center gap-12', 'md:grid-cols-2')}>
    <!-- Imagen -->
    <div
      class={clsx(
        'justify-self-center ',
        reverse ? 'md:order-2 md:justify-self-end' : 'md:justify-self-start'
      )}
    >
      <div
        class={clsx(
          'aspect-square w-full max-w-72 mx-auto overflow-hidden bg-slate-100 shadow-md',
          // Mobile shape
          'rounded-2xl',
          // Desktop blob
          'md:rounded-[48%]',
          // Tamaño controlado - Mobile FIRST
          'sm:max-w-sm md:w-72 md:max-w-none'
        )}
      >
        <Image src={image} alt={title} class="h-full w-full object-cover" />
      </div>
    </div>

    <!-- Texto -->
    <div class={clsx(reverse && 'md:order-1', 'flex flex-col gap-4')}>
      <h3 class="text-primary mb-3 text-xl font-semibold">
        {title}
      </h3>

      <p class="text-muted-foreground leading-relaxed" set:html={description} />
      <Button href={buttonRoute} variant="primary" class="mt-4 w-fit text-lg"
        >Más información</Button
      >
    </div>
  </div>
</section>
