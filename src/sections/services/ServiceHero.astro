---
import Hero from '@/components/Hero.astro';
import { Droplets } from '@lucide/astro';
import type { ImageMetadata } from 'astro';

interface ServiceHeroProps {
  title: string;
  subtitle: string;
  badge: string;
  heroImage: ImageMetadata;
  heroAlt?: string;
  ctaHref?: string;
}

const {
  title,
  subtitle,
  badge,
  heroImage,
  heroAlt,
  ctaHref = '#contacto',
} = Astro.props as ServiceHeroProps;
---

<Hero
  variant="service"
  title={title}
  subtitle={subtitle}
  badge={{ text: badge, Icon: Droplets }}
  image={heroImage}
  imageAlt={heroAlt}
  cta={[{ text: 'Solicitar Cotización', href: ctaHref, variant: 'primary', icon: true }]}
/>
