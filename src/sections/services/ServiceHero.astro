---
import Button from '@/components/Button.astro';
import { Droplets } from '@lucide/astro';
import { Image } from 'astro:assets';

interface ServiceHeroProps {
  title: string;
  subtitle: string;
  badge: string;
  heroImage: ImageMetadata;
  heroAlt?: string;
  ctaHref?: string;
}

const {
  title,
  subtitle,
  badge,
  heroImage,
  heroAlt,
  ctaHref = '#contacto',
} = Astro.props as ServiceHeroProps;
---

<section
  class="bg-navy-900 relative flex min-h-[80vh] w-full items-center justify-center overflow-hidden"
>
  {/* Background Image */}
  <div class="absolute inset-0 z-0">
    <Image src={heroImage} alt={heroAlt || title} class="h-full w-full object-cover" />
    {/* linear Overlay */}

    <div
      class="from-navy-900/90 via-navy-900/50 absolute inset-0 bg-linear-to-br to-teal-900/30 mix-blend-multiply"
    >
    </div>
    <div class="absolute inset-0 bg-black/10"></div>
  </div>

  {/* Decorative Elements */}
  <div class="pointer-events-none absolute top-0 left-0 z-10 h-full w-full overflow-hidden">
    <div
      class="animate-pulse-slow bg-accent-500/20 absolute -top-20 -right-20 h-96 w-96 rounded-full blur-3xl"
    >
    </div>
    <div class="from-background absolute bottom-0 left-0 h-32 w-full bg-linear-to-t to-transparent">
    </div>
  </div>

  <div
    class="relative z-20 container mx-auto flex max-w-5xl flex-col items-start px-6 pt-20 md:px-12"
  >
    {/* Badge */}
    <div
      class="animate-fade-up mb-6 opacity-0"
      style="animation-delay: 100ms; animation-fill-mode: forwards;"
    >
      <span
        class="text-background inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-sm font-medium tracking-wide uppercase backdrop-blur-md"
      >
        <Droplets class="text-accent-400 h-3.5 w-3.5" />
        {badge}
      </span>
    </div>

    {/* Title */}
    <h1
      class="animate-fade-up text-background mb-6 max-w-4xl text-4xl leading-[1.1] font-bold opacity-0 md:text-6xl lg:text-7xl"
      style="animation-delay: 200ms; animation-fill-mode: forwards;"
    >
      {title}
    </h1>

    {/* Subtitle */}
    <p
      class="animate-fade-up mb-10 max-w-2xl text-lg leading-relaxed text-gray-200 opacity-0 md:text-xl"
      style="animation-delay: 300ms; animation-fill-mode: forwards;"
    >
      {subtitle}
    </p>

    {/* CTA */}
    <div
      class="animate-fade-up opacity-0"
      style="animation-delay: 400ms; animation-fill-mode: forwards;"
    >
      <Button
        href={ctaHref}
        variant="primary"
        size="lg"
        icon={true}
        class="bg-accent! text-background hover:bg-accent-600! border-none shadow-lg! shadow-teal-500/30!"
      >
        Solicitar Cotización
      </Button>
    </div>
  </div>
</section>

<style>
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-up {
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .animate-pulse-slow {
    animation: pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>
