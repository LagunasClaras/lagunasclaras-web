---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  title: string;
  steps: string[];
  image?: ImageMetadata;
}

const { title, steps, image } = Astro.props;
---

<section class="py-16 md:py-24">
  <div class="container mx-auto max-w-6xl px-6 md:px-12">
    <div class="flex flex-col gap-12 lg:flex-row lg:items-center">
      <!-- Text Content -->
      <div class="flex-1">
        <h2 class="text-primary mb-6 text-3xl font-bold md:text-4xl">
          {title}
        </h2>
        <div class="space-y-4 text-lg leading-relaxed text-slate-700">
          {steps.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>

      <!-- Image or Diagram Placeholder -->
      <div class="flex-1">
        {
          image ? (
            <div class="relative flex aspect-video w-full items-center justify-center overflow-hidden rounded-2xl shadow-xl">
              <Image src={image} alt={title} class="absolute inset-0 h-full w-full object-cover" />
            </div>
          ) : (
            <div class="relative flex aspect-video w-full items-center justify-center rounded-2xl border-2 border-dashed border-slate-200 bg-slate-50 p-8 shadow-inner">
              <div class="relative h-48 w-full max-w-sm rounded-xl border-2 border-slate-300 bg-white p-4 shadow-lg">
                <!-- Labels -->
                <div class="bg-primary absolute -top-3 left-4 rounded-full px-3 py-1 text-xs font-bold text-white">
                  Canasto Recolector
                </div>

                <!-- Internal Components Representation -->
                <div class="flex h-full flex-col justify-end gap-2">
                  <div class="relative flex h-12 w-full items-center justify-center rounded border border-slate-200 bg-slate-100">
                    <div class="text-xs font-semibold text-slate-500">Sistema Roller</div>
                    <div class="absolute top-1/2 -right-3 h-8 w-8 -translate-y-1/2 rounded-full border border-slate-300 bg-slate-50" />
                  </div>
                  <div class="flex h-8 w-3/4 items-center justify-center self-center rounded border border-emerald-200 bg-emerald-100">
                    <div class="text-xs font-bold text-emerald-700">Barra de Corte Frontal</div>
                  </div>
                </div>

                <div class="absolute right-4 -bottom-3 rounded-full bg-slate-600 px-3 py-1 text-xs font-bold text-white">
                  Profundidad Ajustable
                </div>
              </div>
              <p class="absolute bottom-4 text-sm font-medium text-slate-400">
                Esquema de funcionamiento
              </p>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
