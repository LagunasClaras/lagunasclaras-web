---
import { TriangleAlert, XCircle, OctagonAlert as AlertOctagon, Ban } from '@lucide/astro';

interface Props {
  title: string;
  description: string;
  bullets: string[];
}

const { title, description, bullets } = Astro.props;

const icons = [TriangleAlert, XCircle, AlertOctagon, Ban];
---

<section class="bg-background w-full overflow-hidden py-12 md:py-16" id="problem-section">
  <div class="container mx-auto max-w-6xl px-6 md:px-12">
    <div class="flex flex-col items-start gap-12 lg:flex-row lg:gap-20">
      {/* Left Column — Text */}
      <div class="reveal-on-scroll w-full lg:sticky lg:top-32 lg:w-5/12">
        <span class="mb-3 block font-semibold tracking-wider text-teal-600 uppercase">
          El Desafío
        </span>
        <h2 class="text-navy-900 mb-6 text-3xl font-bold md:text-4xl">
          {title}
        </h2>
        <p class="text-lg leading-relaxed text-gray-600">
          {description}
        </p>
      </div>

      {/* Right Column — Cards */}
      <div class="grid w-full grid-cols-1 gap-4 sm:grid-cols-2 lg:w-7/12">
        {
          bullets.map((bullet, index) => {
            const Icon = icons[index % icons.length];
            return (
              <div
                class="reveal-on-scroll flex items-start gap-4 rounded-xl border border-gray-100 bg-white p-5 shadow-sm"
                style={`transition-delay: ${index * 100}ms`}
              >
                <div class="shrink-0 rounded-lg bg-red-50 p-2">
                  <Icon class="h-5 w-5 text-red-500" />
                </div>
                <span class="font-medium text-gray-700">{bullet}</span>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<script>
  function setupObserver() {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal-on-scroll').forEach((element) => {
      observer.observe(element);
    });
  }

  // Run on initial load and navigation
  document.addEventListener('astro:page-load', setupObserver);
</script>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-on-scroll.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
