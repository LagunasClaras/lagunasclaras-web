---
import { ArrowLeftRight } from '@lucide/astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface BeforeAfter {
  before: ImageMetadata; // Image path
  after: ImageMetadata; // Image path
}

interface Props {
  title?: string;
  subtitle?: string;
  beforeAfter: BeforeAfter;
}

const { title, subtitle, beforeAfter } = Astro.props;
---

<section class="w-full py-12 md:py-16">
  <div class="container mx-auto px-6 md:px-12">
    {
      (title || subtitle) && (
        <div class="mb-12 text-center">
          {title && <h2 class="text-primary mb-4 text-3xl font-bold md:text-4xl">{title}</h2>}
          {subtitle && <p class="mx-auto max-w-2xl text-gray-600">{subtitle}</p>}
        </div>
      )
    }

    {/* Before/After Slider */}
    <div
      class="group relative mx-auto mb-20 aspect-1/1 w-full max-w-5xl cursor-ew-resize overflow-hidden rounded-2xl shadow-2xl select-none md:aspect-video"
      id="before-after-slider"
    >
      {/* After Image (Background) */}
      <div class="absolute inset-0 flex items-center justify-center bg-gray-100">
        <Image
          src={beforeAfter.after}
          alt="Después"
          class="absolute inset-0 h-full w-full object-cover"
        />

        <div
          class="absolute top-6 right-6 z-10 rounded-full bg-teal-500/80 px-4 py-1 text-sm font-medium text-white backdrop-blur-md"
        >
          Después
        </div>
      </div>

      {/* Before Image (Foreground with Clip Path) */}
      <div
        class="slider-foreground absolute inset-0 flex items-center justify-center border-r-2 border-white bg-gray-200 will-change-[clip-path]"
        style="clip-path: inset(0 50% 0 0);"
      >
        <Image
          src={beforeAfter.before}
          alt="Antes"
          class="absolute inset-0 h-full w-full object-cover"
        />

        <div
          class="absolute top-6 left-6 z-10 rounded-full bg-black/50 px-4 py-1 text-sm font-medium text-white backdrop-blur-md"
        >
          Antes
        </div>
      </div>

      {/* Slider Handle */}
      <div
        class="slider-handle absolute top-0 bottom-0 z-20 w-1 cursor-ew-resize bg-white shadow-lg will-change-transform"
        style="left: 50%;"
      >
        <div
          class="absolute top-1/2 left-1/2 flex h-12 w-12 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-white text-teal-600 shadow-xl transition-transform group-hover:scale-110"
        >
          <ArrowLeftRight class="h-5 w-5" />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function setupBeforeAfter() {
    // Before/After Slider Logic
    const slider = document.getElementById('before-after-slider');
    if (slider) {
      const foreground = slider.querySelector('.slider-foreground') as HTMLElement;
      const handle = slider.querySelector('.slider-handle') as HTMLElement;
      let isDragging = false;

      const updateSlider = (x: number) => {
        const rect = slider.getBoundingClientRect();
        // Calculate percentage (0 to 100)
        let percentage = ((x - rect.left) / rect.width) * 100;
        percentage = Math.max(0, Math.min(100, percentage));

        if (foreground) foreground.style.clipPath = `inset(0 ${100 - percentage}% 0 0)`;
        if (handle) handle.style.left = `${percentage}%`;
      };

      const startDrag = () => {
        isDragging = true;
      };
      const stopDrag = () => {
        isDragging = false;
      };

      const onMove = (e: MouseEvent | TouchEvent) => {
        if (!isDragging) return;

        let clientX;
        if (window.TouchEvent && e instanceof TouchEvent) {
          clientX = e.touches[0].clientX;
        } else if (e instanceof MouseEvent) {
          clientX = e.clientX;
        }

        if (clientX) {
          // Ensure clientX is defined
          updateSlider(clientX);
        }
      };

      // Mouse events
      slider.addEventListener('mousedown', startDrag);
      window.addEventListener('mouseup', stopDrag);
      window.addEventListener('mousemove', onMove);

      // Touch events
      slider.addEventListener('touchstart', startDrag, { passive: true });
      window.addEventListener('touchend', stopDrag);
      window.addEventListener('touchmove', onMove, { passive: true });
    }
  }

  document.addEventListener('astro:page-load', setupBeforeAfter);
</script>
