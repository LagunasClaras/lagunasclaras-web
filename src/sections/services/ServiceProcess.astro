---
import { Settings, CircleCheck, Truck } from '@lucide/astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface ProcessStep {
  title: string;
  description: string;
  image?: ImageMetadata;
}

interface Props {
  steps: ProcessStep[];
}

const { steps } = Astro.props;

const icons = [Settings, CircleCheck, Truck];
---

<section class="bg-background w-full overflow-hidden py-12 md:py-16">
  <div class="container mx-auto px-6 md:px-12">
    <div class="reveal-on-scroll mb-20 text-center">
      <h2 class="text-navy-900 mb-4 text-3xl font-bold md:text-5xl">Nuestro Proceso</h2>
      <div class="mx-auto h-1.5 w-20 rounded-full bg-teal-500"></div>
    </div>

    <div class="space-y-24">
      {
        steps.map((step, index) => {
          const isEven = index % 2 === 0;
          const Icon = icons[index % icons.length];
          return (
            <div
              class={`flex flex-col ${isEven ? 'lg:flex-row' : 'lg:flex-row-reverse'} items-center gap-12 lg:gap-20`}
            >
              {/* Image Placeholder */}
              <div
                class={`process-reveal w-full lg:w-1/2 ${isEven ? 'translate-x-[-50px]' : 'translate-x-[50px]'} opacity-0 transition-all duration-700`}
              >
                <div class="group relative flex aspect-4/3 items-center justify-center overflow-hidden rounded-2xl bg-linear-to-br from-gray-100 to-gray-200 shadow-lg">
                  {step.image ? (
                    <Image
                      src={step.image}
                      alt={step.title}
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                    />
                  ) : (
                    <div class="bg-navy-900/5 group-hover:bg-navy-900/10 absolute inset-0 transition-colors duration-500" />
                  )}

                  {!step.image && <Icon class="text-navy-900/20 relative z-10 h-16 w-16" />}

                  {/* Step Number Badge */}
                  <div class="absolute top-6 left-6 z-20 flex h-12 w-12 items-center justify-center rounded-full bg-white text-xl font-bold text-teal-600 shadow-md">
                    0{index + 1}
                  </div>
                </div>
              </div>

              {/* Text Content */}
              <div
                class={`process-reveal w-full lg:w-1/2 ${isEven ? 'translate-x-[50px]' : 'translate-x-[-50px]'} opacity-0 transition-all delay-200 duration-700`}
              >
                <span class="mb-4 block text-6xl font-bold text-gray-100 select-none">
                  0{index + 1}
                </span>
                <h3 class="text-navy-900 mb-4 text-2xl font-bold md:text-3xl">{step.title}</h3>
                <p class="text-lg leading-relaxed text-gray-600">{step.description}</p>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<script>
  function setupProcessObserver() {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.15,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // Remove transform classes to reset position
          entry.target.classList.remove('translate-x-[-50px]', 'translate-x-[50px]', 'opacity-0');
          // Add visible class if needed for other styles, but mainly rely on removing the initial offset/opacity
          entry.target.classList.add('opacity-100', 'translate-x-0');

          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.process-reveal').forEach((element) => {
      observer.observe(element);
    });
  }

  document.addEventListener('astro:page-load', setupProcessObserver);
</script>
