---
import { Leaf, ShieldCheck, Sprout } from '@lucide/astro';

const Content = {
  title: 'Compromiso ambiental',
  description:
    'Somos respetuosos con el medio ambiente: no utilizamos productos químicos. Nuestro enfoque es 100% mecánico y manual.',
  benefits: [
    {
      title: 'Intervención sin químicos',
      description: 'Preservamos la calidad del agua evitando contaminantes.',
      Icon: ShieldCheck,
    },
    {
      title: 'Cuidado del ecosistema',
      description: 'Respetamos la fauna y flora local durante el proceso.',
      Icon: Sprout,
    },
    {
      title: 'Trabajo eficiente y sustentable',
      description: 'Maquinaria diseñada para minimizar el impacto ambiental.',
      Icon: Leaf,
    },
  ],
};
---

<section class="from-accent/10 to-primary-soft bg-linear-to-b py-16 md:py-20">
  <div class="container mx-auto px-4 text-center">
    <div class="mx-auto mb-12 max-w-3xl">
      <h2 class="text-primary mb-6 text-3xl font-bold md:text-4xl">
        {Content.title}
      </h2>
      <p class="text-foreground/80 text-lg leading-relaxed">
        {Content.description}
      </p>
    </div>

    <div class="mx-auto grid max-w-5xl grid-cols-1 gap-8 md:grid-cols-3 md:gap-12">
      {
        Content.benefits.map((benefit) => (
          <div class="group flex flex-col items-center rounded-2xl p-6 transition-all hover:-translate-y-1 hover:bg-white/40 hover:shadow-sm">
            <div class="mb-6 flex h-20 w-20 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-600 shadow-sm transition-transform duration-300 group-hover:scale-110 group-hover:shadow-md">
              <benefit.Icon class="h-10 w-10" />
            </div>
            <h3 class="text-foreground mb-3 text-xl font-bold">{benefit.title}</h3>
            <p class="text-muted-foreground text-base">{benefit.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
