---
import Hero from '@/components/Hero.astro';
import desktopImage from '@assets/hero-1920.webp';

const HeroContent = {
  title: 'Más de 10 años manteniendo y recuperando espejos de agua',
  subtitle: 'Lagos, lagunas, ríos y canales. Limpieza y mantenimiento en todo el país.',
  primaryCTA: { text: 'Pedir presupuesto', href: '/contacto' },
  secondaryCTA: { text: 'Ver servicios', href: '/servicios' },
};
---

<Hero
  variant="about"
  title={HeroContent.title}
  subtitle={HeroContent.subtitle}
  image={desktopImage}
  imageAlt="Laguna limpia y mantenida"
  cta={[
    { text: HeroContent.primaryCTA.text, href: HeroContent.primaryCTA.href, variant: 'primary' },
    {
      text: HeroContent.secondaryCTA.text,
      href: HeroContent.secondaryCTA.href,
      variant: 'underline',
    },
  ]}
/>
