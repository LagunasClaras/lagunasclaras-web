---
import { Leaf, Pin, Recycle, Waves } from '@/components/icons';

const Content = {
  title: 'Qué hacemos',
  intro:
    'Cortamos y recolectamos todo tipo de vegetación acuática, así como también los residuos flotantes.',
  cards: [
    {
      title: 'Residuos flotantes',
      description: 'Recolectamos maderas, plásticos, botellas y otros residuos en superficie.',
      Icon: Recycle,
    },
    {
      title: 'Vegetación acuática',
      description: 'Corte y recolección de algas, juncos, camalotes, totoras y más.',
      Icon: Leaf,
    },
    {
      title: 'Mantenimiento y recuperación',
      description: 'Intervenciones para limpiar, mantener y recuperar espejos de agua.',
      Icon: Waves,
    },
    {
      title: 'Distintos entornos',
      description: 'Trabajamos en lagos, lagunas, pantanos, puertos comerciales y marinas.',
      Icon: Pin,
    },
  ],
};
---

<section class="bg-slate-50 py-16 md:py-24">
  <div class="container mx-auto px-4 text-center">
    <div class="mx-auto mb-16 max-w-3xl">
      <h2 class="text-primary mb-6 text-3xl font-bold md:text-4xl">
        {Content.title}
      </h2>
      <p class="text-foreground/80 text-lg leading-relaxed">
        {Content.intro}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        Content.cards.map((card) => (
          <div class="bg-background group relative flex flex-col items-center rounded-2xl p-8 text-center shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
            <div class="bg-primary/10 text-primary group-hover:bg-primary mb-6 flex h-16 w-16 items-center justify-center rounded-full transition-colors group-hover:text-white">
              <card.Icon className="h-8 w-8" />
            </div>
            <h3 class="text-foreground mb-3 text-xl font-bold">{card.title}</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">{card.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
