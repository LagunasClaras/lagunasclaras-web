---
import Footer from '@/components/Footer.astro';
import Navbar from '@/components/navbar/Navbar.astro';
import Toast from '@/components/Toast.astro';
import WhatsAppButton from '@/components/WhatsAppButton.astro';
import '@/styles/global.css';
import Analytics from '@vercel/analytics/astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Lagunas Claras',
  description = 'Mantenimiento y recuperación de lagos, lagunas y espejos de agua',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {
      !Astro.slots.has('default') && (
        <>
          <title>{title}</title>
          <meta name="description" content={description} />
        </>
      )
    }
    <ClientRouter />
    <meta
      name="keywords"
      content="lagunas claras, mantenimiento lagunas, recuperación lagunas, mantenimiento lagos, recuperación lagos"
    />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />
    <meta name="yandex" content="index, follow" />

    <link rel="icon" type="image/svg+xml" href="/logo.png" />
    <link rel="sitemap" href="/sitemap.xml" />
    <!-- Schema JSON-LD for better google seo -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "${LAGUNAS_INFO.companyName}",
        "url": "https://lagunasclaras.com.ar",
        "image": "https://lagunasclaras.com.ar/og/lagunas-claras-og.webp",
        "telephone": "${LAGUNAS_INFO.contacts.gustavo.phoneE164}",
        "email": "${LAGUNAS_INFO.email}",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "${LAGUNAS_INFO.location.address}",
          "addressLocality": "Tigre",
          "addressRegion": "Buenos Aires",
          "addressCountry": "AR"
        },
        "areaServed": "Argentina",
        "description": "Empresa especializada en mantenimiento de lagos, lagunas y espejos de agua sin uso de químicos."
      }
    </script>
    <slot />
  </head>

  <body class="bg-background text-foreground flex min-h-screen flex-col antialiased">
    <header>
      <Navbar />
    </header>

    <main id="main-content" class="flex-1">
      <slot name="main" />
    </main>

    <Footer />
    <WhatsAppButton />
    <Toast />
    <Analytics />
  </body>
</html>
<style is:global>
  @import '@/styles/global.css';
</style>
