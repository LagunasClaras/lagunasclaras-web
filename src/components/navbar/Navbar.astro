---
import type { NavbarContent } from './navbar.types';
import MobileMenu from './MobileMenu.astro';
import HamburgerButton from './HamburgerButton.astro';

const content: NavbarContent = {
  brandTitle: 'Lagunas Claras',
  links: [
    { title: 'Home', href: '/' },
    { title: 'Quienes Somos', href: '/quienes-somos' },
    { title: 'Servicios', href: '/servicios' },
    { title: 'Clientes', href: '/clientes' },
    { title: 'Faq', href: '/faq' },
    { title: 'Contacto', href: '/contacto' },
  ],
};

const { brandTitle, links } = content;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isTransparentPage =
  currentPath === '/' || currentPath === '/quienes-somos' || currentPath.startsWith('/servicios/');
---

<nav
  id="navbar"
  data-transparent-page={isTransparentPage.toString()}
  data-scrolled="false"
  data-menu-open="false"
  class="group fixed top-0 left-0 z-100 w-full transition-all duration-300"
>
  <!-- Background bar -->
  <div
    id="navbar-bg"
    class="group-data-[scrolled=true]:bg-background group-data-[transparent-page=false]:bg-background absolute inset-0 h-20 transition-all duration-300 group-data-[scrolled=true]:shadow-md group-data-[scrolled=true]:backdrop-blur group-data-[transparent-page=false]:shadow-md group-data-[transparent-page=false]:backdrop-blur group-data-[transparent-page=true]:group-data-[scrolled=false]:bg-transparent"
  >
  </div>

  <div class="relative z-50 mx-auto flex h-20 w-[80%] items-center justify-end md:justify-between">
    <!-- Logo -->
    <a
      href="/"
      id="nav-logo"
      class="relative z-10 hidden max-h-[80px] items-center gap-2 text-lg font-bold transition-opacity duration-300 group-data-[menu-open=true]:pointer-events-none group-data-[menu-open=true]:opacity-0 md:flex"
    >
      <img
        src="/logo.png"
        alt="Lagunas Claras"
        width="128"
        height="80"
        class="max-h-[80px] w-40 min-w-6"
      />
      <!-- <span
        id="nav-title"
        class="text-primary-foreground group-data-[scrolled=true]:text-primary group-data-[transparent-page=false]:text-primary font-semibold transition-colors duration-300"
        >{brandTitle}</span
      > -->
    </a>

    <!-- Desktop Navigation Links -->
    <ul class="hidden gap-6 text-base font-medium md:flex">
      {
        links.map((link) => {
          const isActive =
            link.href === '/' ? currentPath === '/' : currentPath.includes(link.href);
          return (
            <li class="group/link transition-all duration-300 hover:translate-y-2 hover:scale-110">
              <a
                href={link.href}
                data-astro-prefetch
                class:list={[
                  'nav-link transition-colors duration-300',
                  isActive ? 'active' : '',
                  'text-primary-foreground',
                  'group-data-[scrolled=true]:text-primary',
                  'group-data-[transparent-page=false]:text-primary',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {link.title}
              </a>
            </li>
          );
        })
      }
    </ul>

    <!-- Mobile Menu Button -->
    <HamburgerButton
      id="menu-toggle"
      class="text-primary-foreground group-data-[scrolled=true]:text-primary group-data-[transparent-page=false]:text-primary group-data-[menu-open=true]:text-primary! z-60 transition-colors duration-300 md:hidden"
    />
  </div>
  <MobileMenu links={links} brandTitle={brandTitle} />
</nav>

<script>
  const initNavbar = () => {
    const navbar = document.getElementById('navbar');
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuOverlay = document.getElementById('menu-overlay');

    if (!navbar || !menuToggle || !mobileMenu || !menuOverlay) return;

    let isMenuOpen = false;

    const toggleMenu = () => {
      isMenuOpen = !isMenuOpen;
      navbar.dataset.menuOpen = isMenuOpen.toString();

      menuToggle.classList.toggle('open');
      mobileMenu.classList.toggle('translate-x-full');
      mobileMenu.classList.toggle('translate-x-0');
      menuOverlay.classList.toggle('opacity-0');
      menuOverlay.classList.toggle('opacity-100');
      menuOverlay.classList.toggle('pointer-events-none');
      mobileMenu.classList.toggle('active');

      // Body scroll lock
      if (isMenuOpen) {
        document.body.style.overflow = 'hidden';
      } else {
        document.body.style.overflow = '';
      }
    };

    const updateScrollState = () => {
      const isScrolled = window.scrollY > 0;
      navbar.dataset.scrolled = isScrolled.toString();
    };

    menuToggle.addEventListener('click', toggleMenu);
    menuOverlay.addEventListener('click', toggleMenu);

    // Initialize scroll state
    updateScrollState();

    // TODO: Refactor to usage of CSS scroll-driven animations when browser support is better
    // See src/docs/features.md for more details
    window.addEventListener('scroll', updateScrollState);

    // Resize handler to close menu on desktop
    const onResize = () => {
      if (window.innerWidth >= 768 && isMenuOpen) {
        toggleMenu();
      }
    };
    window.addEventListener('resize', onResize);

    // Cleanup
    const cleanup = () => {
      window.removeEventListener('scroll', updateScrollState);
      window.removeEventListener('resize', onResize);
      document.body.style.overflow = ''; // Reset scroll lock
    };

    document.addEventListener('astro:before-swap', cleanup, { once: true });
  };

  // Run on initial load and subsequent navigations
  document.addEventListener('astro:page-load', initNavbar);
</script>
