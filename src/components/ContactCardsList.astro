---
import { Mail, MapPin } from '@lucide/astro';
import { WhatsApp } from './icons';

export interface ContactCard {
  title: string;
  description: string;
  icon: any;
  href?: string;
  colorScheme: 'green' | 'blue' | 'slate';
}

const colorStyles = {
  green: {
    icon: 'bg-green-500/20 text-green-600 ring-green-500/20',
  },
  blue: {
    icon: 'bg-blue-500/20 text-blue-600 ring-blue-500/20',
  },
  slate: {
    icon: 'bg-slate-500/20 text-slate-600 ring-slate-500/20',
  },
};

const cards: ContactCard[] = [
  {
    title: 'WhatsApp',
    description: '+54 9 11 387 0205',
    icon: WhatsApp,
    colorScheme: 'green',
  },
  {
    title: 'Email',
    description: 'lagunasclaras@gmail.com',
    icon: Mail,
    colorScheme: 'blue',
  },
  {
    title: 'Ubicación',
    description: 'Santa Cruz 419, Benavidez, Provincia de Buenos Aires',
    icon: MapPin,
    href: 'https://maps.app.goo.gl/rPkX2yuDpUcGkXZYA',
    colorScheme: 'slate',
  },
];
---

<div class="flex flex-col gap-4">
  {
    cards.map((card: ContactCard) => (
      <a
        href={card.href}
        target={card.href?.startsWith('http') ? '_blank' : undefined}
        rel={card.href?.startsWith('http') ? 'noopener noreferrer' : undefined}
        class={`group bg-card flex items-center gap-5 rounded-2xl border border-white/20 p-5 shadow-xl ring-1 ring-white/10 backdrop-blur-xl ${card.href ? 'transition-colors hover:bg-white/50' : ''}`}
      >
        <div
          class={`flex h-12 w-12 shrink-0 items-center justify-center rounded-full ring-1 ${colorStyles[card.colorScheme].icon}`}
        >
          <card.icon class="h-6 w-6" />
        </div>
        <div>
          <p class="text-sm text-slate-800">{card.title}</p>
          <h3 class="text-primary font-semibold">{card.description}</h3>
        </div>
      </a>
    ))
  }
</div>
