---
import { Mail, MapPin, Phone } from '@lucide/astro';
import { Image } from 'astro:assets';
import logoGS from '@/assets/logo-gs.png';
import { Facebook, Instagram, LinkedIn, TikTok } from './icons';

import { LAGUNAS_INFO } from '@/config/lagunasInfo';

const FooterContent = {
  Title: LAGUNAS_INFO.companyName,
  links: [
    { text: 'Home', href: '/' },
    { text: 'About', href: '/about' },
    { text: 'Services', href: '/services' },
    { text: 'Clients', href: '/clients' },
  ],
  networks: [
    { text: 'Instagram', href: LAGUNAS_INFO.social.instagram, Icon: Instagram },
    { text: 'LinkedIn', href: LAGUNAS_INFO.social.linkedin, Icon: LinkedIn },
    { text: 'Facebook', href: LAGUNAS_INFO.social.facebook, Icon: Facebook },
    { text: 'TikTok', href: LAGUNAS_INFO.social.tiktok, Icon: TikTok },
  ],
  cta: [
    { text: 'lagunasclaras@gmail.com', href: `/`, Icon: Mail },
    {
      text: LAGUNAS_INFO.contacts.gustavo.phone,
      href: `tel:${LAGUNAS_INFO.contacts.gustavo.phoneE164}`,
      Icon: Phone,
    },
    { text: 'Ubicación', href: LAGUNAS_INFO.location.mapsUrl, Icon: MapPin },
  ],
  copyright: `© ${new Date().getFullYear()} ${LAGUNAS_INFO.companyName}. All rights reserved.`,
};
---

<!-- TODO: Add real links, logo -->
<footer class="bg-primary py-4 md:py-0">
  <div class="mx-auto w-[90%] max-w-4xl md:w-full md:p-4">
    <div
      class="flex flex-col items-center gap-8 md:h-32 md:flex-row md:items-center md:justify-between"
    >
      <!-- Logo y Redes Sociales -->
      <div class="flex w-full flex-col items-center gap-6 md:w-auto md:items-start md:gap-4">
        <div class="text-primary-foreground flex flex-col items-center gap-2">
          <Image
            src={logoGS}
            alt={FooterContent.Title}
            class="h-20 w-72 object-contain md:h-24 md:w-48"
          />
        </div>
        <div
          class="flex flex-row justify-center gap-8 opacity-80 md:w-full md:justify-center md:gap-6"
        >
          {
            FooterContent.networks.map(({ Icon, href }) => (
              <a href={href} class="relative transition-colors" target="_blank">
                <Icon class="text-primary-foreground h-6 w-6 min-w-6" />
              </a>
            ))
          }
        </div>
      </div>

      <!-- Links Desktop (Hidden en Mobile) -->
      <div
        class="text-primary-foreground hidden w-full flex-col gap-3 text-base font-medium md:flex md:w-auto"
      >
        {
          FooterContent.links.map((link) => (
            <a href={link.href} class="relative transition-colors hover:underline">
              {link.text}
            </a>
          ))
        }
      </div>

      <!-- Contactos -->
      <div class="flex flex-col gap-5 md:gap-6">
        {
          FooterContent.cta.map(({ Icon, href, text }) => (
            <a href={href} class="relative flex items-center gap-3 transition-colors md:gap-2">
              <Icon class="text-primary-foreground h-6 w-6 min-w-6" />
              <span class="text-primary-foreground text-sm font-semibold">{text}</span>
            </a>
          ))
        }
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-4 border-t border-white/20 pt-4 text-center md:hidden">
      <p class="text-primary-foreground/60 text-xs">{FooterContent.copyright}</p>
    </div>
  </div>
  <div class="hidden w-full text-center md:block">
    <p class="text-primary-foreground/60 text-xs">{FooterContent.copyright}</p>
  </div>
</footer>
